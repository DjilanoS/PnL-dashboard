# --- Server ---
NODE_ENV=development
PORT=3000
# Comma-free single origin of the deployed frontend (used for CORS).
FRONTEND_ORIGIN=http://localhost:5173

# --- Auth ---
# Generate a long random string for production (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# --- Discord OAuth (Sign in with Discord) ---
# Create an app at https://discord.com/developers/applications → OAuth2, copy the
# Client ID/Secret, and add a redirect URI EXACTLY matching DISCORD_CALLBACK_URL
# (register both the dev and prod URLs). Scope used: identify.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
FRONTEND_AUTH_CALLBACK=http://localhost:5173/auth/callback

# --- Database (MongoDB Atlas) ---
# mongodb+srv://user:pass@cluster.xxxx.mongodb.net/pnl?retryWrites=true&w=majority
MONGODB_URI=

# --- Solana (Helius) ---
# Your Helius API key. SOLANA_RPC_URL is derived from it if left blank.
HELIUS_API_KEY=
SOLANA_RPC_URL=

# --- Sui ---
# Leave blank to use the public mainnet fullnode (getFullnodeUrl('mainnet')).
SUI_RPC_URL=

# --- Cron ---
# Shared secret required by POST /cron/snapshot (set the same value in Vercel Cron).
CRON_SECRET=dev-cron-secret
